project

import ./plains

eval println $.
eval println $/
eval println &.
eval println &/
eval println "none: &(dir)"

foo:[(cd -)]: &(dir)/foobar
	println &(dir)
	println &.
	println &/

%/foobar:[(cd -) (shell -veo)]
	@echo $(CWD)
	@pwd
	@touch $@ && ls $@

plain-foo-1:
	error "$@ undefined"
plain-foo-2:
	error "$@ undefined"
plain:[(plain text)]
	&{plain-foo-1}; &{plain-foo-2}; &{plains->plain-foo-3}
