module

start:!: a.out
	shell $< Test

a.out:[shell]: a.o
	gcc -o $@ $<

a.o:[shell]: a.c
	gcc -c -o $@ $<

a.c:[shell]:
	echo "// Generated by a.smart, don't edit this file." > $@
	echo "#include <stdio.h>" >> $@
	echo "int main(int argc, char**argv) {" >> $@
	echo "    printf(\"Hello, %s!\", argv[1]);" >> $@
	echo "}" >> $@
