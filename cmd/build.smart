project example

foobar = $(println 'foobar')
test = 'this is a test'

start: run-rule
	println 'I\'m just an example!'

run-rule: # a bare entry doing nothing
	println 'Run another rule..'
	run something 'a' 'b' 'c'

something: # a bare entry doing nothing
	println 'I\'m just an example! (called)'
	foobar
	test
