project example

foobar = $(println 'foobar')
test = 'this is a test'

start: run-rule
	println 'I\'m just an example!'

run-rule: # a rule called another rule
	println 'Run another rule..'
	something 'a' 'b' 'c'

something: # a bare entry doing nothing
	println 'I\'m just an example! (called)'
	println $(foobar) $(test)
	foobar
	test

eval something
eval foobar
eval test
