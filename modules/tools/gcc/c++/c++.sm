project (tools/gcc/c)

files (
    '*.cpp' '*.cc' '*.C'
    '*.hpp' '*.hh' '*.H'
)

CXX = g++

CPPFLAGS += -std=c++1z
CXXFLAGS =

# FIXME: naming COMPILE.cc, COMPILE.cpp, COMPILE.C
COMPILE-cc = &CXX &CXXFLAGS &CPPFLAGS &TARGET_ARCH -c
COMPILE-cpp = $COMPILE-cc
COMPILE-C = $COMPILE-cc
COMPILE = $COMPILE-cc

LDFLAGS =

LINK-cc = &CXX &CXXFLAGS &CPPFLAGS &LDFLAGS &TARGET_ARCH
LINK-o = &CXX &LDFLAGS &TARGET_ARCH
LINK = $LINK-cc

ignore:

program:[(cd) ((bin objects)) (compare bin) (stdout) (stderr) (shell)]: &objects
	$LINK $^ &LOADLIBES &LDLIBS -o $@
lib.so:[(cd) ((lib objects)) (compare lib) (stdout) (stderr) (shell)]: &objects
	$LINK -shared $^ &LOADLIBES &LDLIBS -o $@
lib.a:[(cd) ((lib objects)) (compare lib) (stdout) (stderr) (shell)]: &objects
	$ARCHIVE $@ $<
%.o:[(cd) (compare) (stdout) (stderr) (shell)]: %.cpp
	$COMPILE $^ -o $@

# TODO:
#.cc:
#	$(LINK.cc) $^ $(LOADLIBES) $(LDLIBS) -o $@

use:
	println $LINK
	LINK = $LINK
	println $LINK
	COMPILE = $COMPILE
	ARCHIVE = $ARCHIVE
	
	LOADLIBES = $LOADLIBES
	LDLIBS = $LDLIBS
