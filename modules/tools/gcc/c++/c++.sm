module c++

#extensions cpp cc CC C hh h o
extensions (
  unit=( cpp cc CC C )
  header=( hh h )
  object=( o obj )
)

compiler = g++
compile_flags = -std=c++1z

archiver = ar
archive_flags = crus

linker = g++
link_flags =

use:
	compile_flags += $(compile_flags)
	compile = $(compiler) &$(compile_flags) -c
	archive_flags += $(archive_flags)
	archive = $(archiver) &$(archive_flags)
	link_flags += $(link_flags)
	link = $(linker) &$(link_flags)
	libs +=
