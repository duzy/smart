module c++

#extensions cpp cc CC C hh h o
extensions (
  unit=( cpp cc CC C )
  header=( hh h )
  object=( o obj )
)

link_flags =
libs = 

linker = g++
link = $(linker) $(link_flags)

compile_flags = -std=c++1z

compiler = g++
compile = $(compiler) '-c' $(compile_flags)

sources =

