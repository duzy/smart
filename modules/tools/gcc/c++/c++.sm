project (tools/gcc/c)

files (
    *.cpp *.cc *.C
    *.hpp *.hh *.H
)

CXX = g++

CPPFLAGS += -std=c++1z
CXXFLAGS =

# FIXME: naming COMPILE.cc, COMPILE.cpp, COMPILE.C
COMPILE-cc = &(CXX) &(CFLAGS) &(CXXFLAGS) &(CPPFLAGS) &(TARGET_ARCH) -c
COMPILE-cpp = $(COMPILE-cc)
COMPILE-C = $(COMPILE-cc)
COMPILE = $(COMPILE-cc)

LDFLAGS =

LINK-cc = &(CXX) &(CXXFLAGS) &(CPPFLAGS) &(LDFLAGS) &(TARGET_ARCH)
LINK-o = &(CXX) &(LDFLAGS) &(TARGET_ARCH)
LINK = $(LINK-cc)

nothing:

program:[(cd) ((bin objects)) (compare $(bin)) (shell -oe)]: $(objects)
	$(LINK) $^ &(LOADLIBES) &(LDLIBS) -o $(bin)
lib.so:[(cd) ((lib objects)) (compare $(lib)) (shell -oe)]: $(objects)
	$(LINK) -shared $^ &(LOADLIBES) &(LDLIBS) -o $(lib)
lib.a:[(cd) ((lib objects)) (compare $(lib)) (shell -oe)]: $(objects)
	$(ARCHIVE) $(lib) $^

%.o:[(cd) (compare) (shell -oe)]: %.cpp
	$(COMPILE) $^ -o $@
%.o:[(cd) (compare) (shell -oe)]: %.cc
	$(COMPILE) $^ -o $@
%.o:[(cd) (compare) (shell -oe)]: %.C
	$(COMPILE) $^ -o $@

# https://github.com/google/re2/wiki/Syntax
%.cpp %.cc %.C %.h %.hpp %.hh %.H:[(cd) (grep-compare -discard-missing \
    '\s*#\s*include\s*<(.*)>' \
    '\s*#\s*include\s*"(.*)"')]

# TODO:
#.cc:
#	$(LINK.cc) $^ $(LOADLIBES) $(LDLIBS) -o $@

use:
	foo = 
	LINK = $(LINK)
	COMPILE = $(COMPILE)
	ARCHIVE = $(ARCHIVE)
	
	CPPFLAGS = $(CPPFLAGS)
	CXXFLAGS = $(CXXFLAGS)
	
	LDFLAGS = $(LDFLAGS)
	LDLIBS = $(LDLIBS)
	LOADLIBES = $(LOADLIBES)
