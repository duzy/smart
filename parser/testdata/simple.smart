# this is a simple project...
project simple

import (
    "./modules/a"
    "./modules/b"
)

include (
    "./incs/a.smart"
    "./incs/b.smart"
    "./incs/c.smart"
)

instance (
    # proc: self, process, namespace (NAMESPACES(7))
    proc namespace

    # explicitly specify the entrance
    entry start
)

use (
    m1 a b c,
    m2 1 2 3
)

eval (print a b c, 1 2 3)
eval  print a b c # restriction: comma is not allow here
eval  print a b c, print 1 2 3
eval (let (a 1, b 2, c 3)
      (print "a = $a\n")
      (print "b = $b\n")
      (print "c = $c\n")
      (set a 123))

VAR = project scoped var

var = module scoped var

start: print-a print-b
	print "......"
	print "......"
print-a: a.print-var
	print "a.VAR = $(a.VAR)"
print-b: b.print-var
	print "b.VAR = $(b.VAR)"
a b c :
	print $@
