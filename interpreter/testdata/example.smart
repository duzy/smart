# this is an example project
project example

import "fs"
import "./dialects/foo"

TAG_BOOK = book
TAG_TITLE = title

include "part.smart"

BOOK_TITLE_1 = book one
BOOK_TITLE_2 = book two

numbers = -123 +"100"

eval print "this is a test\n"
eval println 'this is a test'

## Starting rule of shell program
start : ! : \
  process.cmd \
  process.xml

process.cmd : [ shell ] :
	echo '$@' && \
	echo 'process.cmd'

process.xml : [ xml (as x), \
  (xml-write-file (xml-search $x, 'book one'), $@) \
  ] :
	<books>
	  <$(TAG_BOOK)>
	    <$(TAG_TITLE)>$(BOOK_TITLE_1)</$(TAG_TITLE)>
	  </$(TAG_BOOK)>
	  <$(TAG_BOOK)>
	    <$(TAG_TITLE)>$(BOOK_TITLE_2)</$(TAG_TITLE)>
	  </$(TAG_BOOK)>
	  <book> <title>  abc  </title> </book>
	</books>

## append rule to `something`
#something::[shell]:
#	echo '$@' >> filename.txt

## the main clause
#eval run start # run is a builtin function
