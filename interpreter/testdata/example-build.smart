# Example to really generate files
project example

import "tools/gcc/c++"

build: ! : example

example : [ (when-outdated) shell (check-file) ] : example.o check-something
	echo $(c++.LINK) -o $@ $< > $@

example.o : [ (when-outdated) shell (check-file) ] : example.txt
	echo $(c++.COMPILE) -o $@ $^ > $@

example.txt : [ (when-outdated) plain (update-file) ]
	#include <iostream>
	int main() {
	  std::cout << "$@" << std::endl;
	}

check-something: [ shell ]
	false
