# Example to really generate files
project example

import "tools/gcc/c++"

example : [ shell, (check-file) ] : example.o
	echo $(c++.LINK) -o $@ $<

example.o : [ shell, (check-file) ] : example.cpp
	echo $(c++.COMPILE) -o $@ $^

example.cpp : [ plain, (write-file) ]:
	#include <iostream>
	int main() {
	  std::cout << "$@" << std::endl;
	}
