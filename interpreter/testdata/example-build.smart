# Example to really generate files
project example

import "tools/gcc/c++"

example : [ shell ] : example.o
	echo $(c++.LINK) -o $@

example.o : [ shell ] : example.cpp
	echo $(c++.COMPILE) -o $@

example.cpp : [ plain, (write-file $-) ]
	#include <iostream>
	int main() {
	  std::cout << "$@" << std::endl;
	}
