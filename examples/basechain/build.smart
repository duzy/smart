project (./base)

GREETING := 'Hello World!'

eval println "test:" $a $b $c 
eval println "test:" $/ 
eval println "test:" $.

run:[(stderr) (stdout) (shell)]: hello
	./bin/hello

hello.cpp:[(plain c++) (update-file)]
	#include <iostream>
	int main(int argc, char** argv) {
	    std::cout <<"$(GREETING)" << std::endl;
	    return 0;
	}
