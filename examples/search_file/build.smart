project

import (
    tools///gcc///c++
)

eval println /////opt///foobar
eval println .///foo///bar

files (
    *.cpp => $./src
    *.o => $./obj
    hello
)

run:[(shell -oe)]: hello
	./hello

hello:[(compare) (shell -e)]: hello.o
	$(LINK) $^ -o $@

hello.o:[(compare) (shell -e)]: hello.cpp
	$(COMPILE) $< -o $@

# TODO: using 'files' scheme
clean:[(shell)]:
	rm -f obj/*.o hello
