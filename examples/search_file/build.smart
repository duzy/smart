project

import (
    tools///gcc///c++
)

eval println /////opt///foobar
eval println .///foo///bar

files (
    '*.cpp' => "$./src"
    '*.o' => "$./obj"
    'hello'
)

run:[(stderr) (stdout) (shell)]: hello
	./hello

hello:[(compare) (stderr) (shell)]: hello.o
	$(LINK) $^ -o $@

hello.o:[(compare) (stderr) (shell)]: hello.cpp
	$(COMPILE) $< -o $@

# TODO: using 'files' scheme
clean:[shell]:
	rm -f obj/*.o hello
